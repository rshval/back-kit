{
  "name": "@rshval/back-kit",
  "version": "1.1.10",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "tsconfig.sites.json"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run",
    "rebuild": "npm run format && npm run lint",
    "lint": "tsc",
    "dev": "nodemon",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "ci": "npm run build && npm run check-format && npm run check-exports && npm run lint && npm run test",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "release": "npm version patch && npm publish && git push --follow-tags"
  },
  "author": "",
  "license": "MIT",
  "description": "Backend toolkit of service factories (create*/build*), validators and Node.js API utilities with DI-friendly patterns",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cyrillic-to-translit-js": "^3.2.1",
    "delay": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.38",
    "lru-cache": "^11.2.6",
    "mongoose": "^9.2.4",
    "nodemailer": "^8.0.1",
    "ora": "^9.3.0",
    "socket.io-client": "^4.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rshval/back-kit.git"
  },
  "homepage": "https://github.com/rshval/back-kit#readme",
  "bugs": {
    "url": "https://github.com/rshval/back-kit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tsconfig.sites.json": "./tsconfig.sites.json",
    "./http-contracts": {
      "types": "./dist/http-contracts.d.ts",
      "import": "./dist/http-contracts.js"
    }
  }
}
